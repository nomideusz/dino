FROM node:22-alpine AS builder

WORKDIR /app

# The archive server is a standalone npm package (its only runtime dependency
# is @anthropic-ai/sdk); everything else is Node built-ins.
COPY server/package.json server/package-lock.json ./
RUN npm ci --omit=dev

COPY server/ ./

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=8080

COPY --from=builder /app ./

EXPOSE 8080

CMD ["node", "server.mjs"]
